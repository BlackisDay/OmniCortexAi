{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "types": ["node", "express"],
    "lib": ["dom", "esnext"],
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": "src",
    "paths":{
        "*": ["*", "ai/*", "math/*", "utils/*"]  // <- add this line
    },
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": [
    "src/**/*",
    "src/ai/**/*"
  ],
  "exclude": ["node_modules"]
}